# For more information, please see the README.md
SUNO_COOKIE=
# 多账号:多个 cookie 用 ||| 分隔(优先于 SUNO_COOKIE);留空则回退到 SUNO_COOKIE 单账号
SUNO_COOKIES=
TWOCAPTCHA_KEY= # Obtain from 2captcha.com
BROWSER=chromium # `chromium` or `firefox`, although `chromium` is highly recommended
BROWSER_GHOST_CURSOR=false
BROWSER_LOCALE=en
BROWSER_HEADLESS=true

# === Diagnostics & Request Logging ===
# 失败诊断(diagnostics/)与请求记录(requests/)保留天数;0 = 不自动清理
DIAG_RETENTION_DAYS=7
# 请求记录里是否包含 cookie/authorization(默认 false 脱敏,避免泄露可复用凭证)
LOG_REQUEST_AUTH=false
# 仅记录这些 route(逗号分隔,留空 = 除 get/get_limit 外全部已接入 route)
# LOG_REQUEST_ROUTES=generate,custom_generate
